// UnifyAPI — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String   @default("box")
  tools       Tool[]
  createdAt   DateTime @default(now())
}

model Provider {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  website     String?
  description String
  tools       Tool[]
  createdAt   DateTime @default(now())
}

model Tool {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  priceUsd    Decimal  @db.Decimal(10, 6)
  inputSchema Json
  tags        String[]
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  // "live" tools proxy a real upstream API; others return realistic mock data
  live        Boolean  @default(false)
  createdAt   DateTime @default(now())

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  usage UsageRecord[]

  @@index([categoryId])
  @@index([providerId])
}

// ─────────────────────────────────────────────────────────────
// Accounts & billing
// ─────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  walletAddress String?
  balanceUsd    Decimal       @default(0) @db.Decimal(12, 6)
  createdAt     DateTime      @default(now())
  apiKeys       ApiKey[]
  usage         UsageRecord[]
  payments      Payment[]
}

model ApiKey {
  id         String        @id @default(cuid())
  hashedKey  String        @unique
  prefix     String // e.g. "uak_live"
  last4      String
  label      String        @default("Default key")
  revoked    Boolean       @default(false)
  createdAt  DateTime      @default(now())
  lastUsedAt DateTime?
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage      UsageRecord[]

  @@index([userId])
}

enum CallStatus {
  success
  error
  unauthorized
  insufficient_funds
}

model UsageRecord {
  id        String     @id @default(cuid())
  status    CallStatus
  costUsd   Decimal    @default(0) @db.Decimal(10, 6)
  latencyMs Int        @default(0)
  createdAt DateTime   @default(now())

  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id])

  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolId])
  @@index([createdAt])
}

enum PaymentStatus {
  pending
  settled
  failed
}

model Payment {
  id        String        @id @default(cuid())
  amountUsd Decimal       @db.Decimal(12, 6)
  scheme    String        @default("x402") // x402 | mock
  network   String        @default("base-sepolia")
  txHash    String?
  payer     String? // payer wallet address
  status    PaymentStatus @default(pending)
  createdAt DateTime      @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

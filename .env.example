# ── Database (required) ───────────────────────────────────────
# Any PostgreSQL connection string. For managed Postgres (Neon, Supabase,
# Prisma Postgres cloud) paste the URL they give you.
DATABASE_URL="postgres://user:password@host:5432/unifyapi?sslmode=require"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
API_KEY_SECRET="generate-a-long-random-string"

# ── Privy auth (optional — falls back to demo login if empty) ──
# Create an app at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# ── x402 crypto payments (optional — simulation mode if empty) ─
X402_PAY_TO=""                                   # 0x... wallet that receives USDC
X402_NETWORK="base-sepolia"                      # or "base" for mainnet
X402_FACILITATOR_URL="https://x402.org/facilitator"
# Mainnet via Coinbase CDP facilitator also needs:
CDP_API_KEY_ID=""
CDP_API_KEY_SECRET=""
